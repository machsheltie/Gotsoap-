---
/**
 * BaseLayout.astro — the site shell every page renders through.
 *
 * Props: { title, description, ogImage?, ogType?, register?, jsonLd?,
 *          mastheadScale?, hideScratchSniff? }
 *   title/description  per-route meta (copy-deck §2), transcribed verbatim.
 *   ogImage            absolute URL to an OG image (optional; Phase 1 supplies).
 *   ogType             OpenGraph type (default 'website').
 *   register           applies a single register to <main> for single-author
 *                      pages (e.g. 'cwaaa' for /pledge, /crisis, /404;
 *                      'porcelain' for /about). Omit on mixed pages (home)
 *                      where each section sets its own register.
 *   mastheadScale      'monumental' on the home only (the magazine cover);
 *                      defaults to 'compact' (the interior running head).
 *   hideScratchSniff   suppress the ScratchSniff gag toast. Required on
 *                      /psas/[slug]: the fixed card crosses the canonical
 *                      poster box on mobile (specs.md §5.1 — nothing may
 *                      cross the poster at rest).
 *   jsonLd             optional JSON-LD object for the page.
 *
 * CHROME (unification, owner-confirmed 2026-07-16): the layout renders the
 * register-correct Masthead directly — derived from `register`, so a CWAAA
 * page cannot accidentally wear campaign chrome (§1). Nav.astro is retired;
 * the §9.1 contents dialog is the one navigation mechanism, site-wide.
 *
 * The viewport-locking "immersive" mode died with the legacy single-viewport
 * home (§3: home uses normal vertical scrolling).
 */
import '../styles/tokens.css';
import '../styles/base.css';
import Seo from '../components/Seo.astro';
import Masthead from '../components/chrome/Masthead.astro';
import Footer from '../components/Footer.astro';
import ScratchSniff from '../components/ScratchSniff.astro';
import { GOATCOUNTER_CODE } from '../config/site';
import type { Register } from '../config/site';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogType?: string;
  register?: Register | 'cwaaa';
  mastheadScale?: 'monumental' | 'compact';
  hideScratchSniff?: boolean;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}
const {
  title,
  description,
  ogImage,
  ogType,
  register,
  mastheadScale = 'compact',
  hideScratchSniff = false,
  jsonLd,
} = Astro.props;

// One header system, two registers (§1): CWAAA pages get the org letterhead,
// everything else gets the campaign nameplate. Derived, not opted into.
const chromeRegister = register === 'cwaaa' ? 'cwaaa' : 'campaign';

const goatCounterEndpoint = `https://${GOATCOUNTER_CODE}.goatcounter.com/count`;

// Critical above-the-fold faces, preloaded (self-hosted; no font CDN).
const preloadFonts = [
  '/fonts/oswald-500.woff2',
  '/fonts/libre-franklin-800.woff2',
  '/fonts/jost-400.woff2',
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- Confirm JS before paint so [data-reveal] hides only when we can reveal it
         (no-JS users are never trapped behind opacity:0). See base.css. -->
    <script is:inline>document.documentElement.classList.add('has-js');</script>

    <!-- §3.1 steam threshold — the first-visit decision, made SYNCHRONOUSLY in
         the head before body paint. Fog exists only under
         `html.steam-first-visit`, added when (a) motion is allowed and (b) this
         session has not seen the sweep. Return visits, storage errors, reduced
         motion, and no-JS therefore all render the default CLEAR state with no
         flash of steam. The class key and the sweep live in
         scripts/steam-hero.ts; the fog CSS lives in homev2/Hero.astro. -->
    <script is:inline>
      (function () {
        var KEY = 'gotsoap:steam-cleared:v1';
        try {
          if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
          if (window.sessionStorage.getItem(KEY)) return;
        } catch (e) {
          return; /* default clear state — the effect never blocks content */
        }
        var html = document.documentElement;
        html.classList.add('steam-first-visit');
        // Failsafe: if a hero exists but its island never takes over, settle
        // to clear and record completion so later navigations are not fogged.
        // On pages WITHOUT a hero the class is dropped but nothing is stored —
        // the visitor still gets their one sweep when they reach the home.
        window.setTimeout(function () {
          var hero = document.getElementById('hero');
          if (hero && hero.getAttribute('data-hero')) return; /* island took over */
          html.classList.remove('steam-first-visit');
          if (hero) {
            try {
              window.sessionStorage.setItem(KEY, '1');
            } catch (e) {}
          }
        }, 3000);
      })();
    </script>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <Seo
      title={title}
      description={description}
      ogImage={ogImage}
      ogType={ogType}
      jsonLd={jsonLd}
    />

    {
      preloadFonts.map((href) => (
        <link
          rel="preload"
          href={href}
          as="font"
          type="font/woff2"
          crossorigin
        />
      ))
    }

    <!-- GoatCounter (privacy-friendly, no-cookie; skips localhost). PRD §6.5 -->
    <script
      is:inline
      data-goatcounter={goatCounterEndpoint}
      async
      src="https://gc.zgo.at/count.js"></script>
  </head>

  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <Masthead register={chromeRegister} scale={mastheadScale} />
    <main id="main" class:list={[register && `register-${register}`]}>
      <slot />
    </main>
    <Footer />
    {!hideScratchSniff && <ScratchSniff />}

    <script>
      // Global scroll-reveal activator (progressive enhancement; styles in base.css).
      // Reveals every [data-reveal] on scroll; immediately under reduced motion or
      // where IntersectionObserver is unavailable. Idempotent with any page-local observer.
      const revealEls = document.querySelectorAll('[data-reveal]');
      if (revealEls.length) {
        const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (reduce || !('IntersectionObserver' in window)) {
          revealEls.forEach((el) => el.classList.add('is-revealed'));
        } else {
          const io = new IntersectionObserver(
            (entries, obs) => {
              for (const e of entries) {
                if (e.isIntersecting) {
                  e.target.classList.add('is-revealed');
                  obs.unobserve(e.target);
                }
              }
            },
            { rootMargin: '0px 0px -10% 0px', threshold: 0.05 },
          );
          revealEls.forEach((el) => io.observe(el));
        }
      }
    </script>
  </body>
</html>

<style>
  body {
    display: flex;
    flex-direction: column;
    min-height: 100dvh;
  }
  main {
    flex: 1 0 auto;
  }
</style>
