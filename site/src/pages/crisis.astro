---
/**
 * /crisis — CWAAA's site-within-a-site. 📋 CWAAA-authored surface.
 * register="cwaaa" makes <main> the full manila document world (PT Serif,
 * ink + stamp). No campaign-register token or fx-* appears here.
 * Meta verbatim (copy §2/§8).
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import CrisisReport from '../components/cwaaa/CrisisReport.astro';
import { crisis } from '../content/crisis';
---

<BaseLayout
  title={crisis.meta.title}
  description={crisis.meta.description}
  register="cwaaa"
>
  <div class="crisis-page container">
    <CrisisReport />
  </div>
</BaseLayout>

<style>
  .crisis-page {
    padding-block: clamp(var(--space-lg), 4vw, var(--space-2xl));
  }
</style>
