---
/**
 * /pledge — The Lather Pledge (Form CW-1). 📋 CWAAA-authored surface.
 * register="cwaaa" hands <main> the CWAAA slots (manila/ink/stamp, PT Serif).
 * design.md §7: the manila document panel sits on a grout-black ground — the
 * one structural token that frames every CWAAA surface (the nav uses it too);
 * no campaign-register token or fx-* appears here. Meta verbatim (copy §2/§7).
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import PledgeForm from '../components/cwaaa/PledgeForm.astro';
import { meta } from '../content/copy';

const pageMeta = meta.pledge;
---

<BaseLayout
  title={pageMeta.title}
  description={pageMeta.description}
  register="cwaaa"
>
  <section class="pledge-stage">
    <PledgeForm />
  </section>
</BaseLayout>

<!--
  The document sits on grout-black (design.md §7). register-cwaaa sets <main>'s
  background to manila; on THIS route only we swap that ground to grout-black so
  the manila Form CW-1 panel reads as a filed document on a desk. Scoped to
  /pledge because a page's styles only ship on pages that render it.
-->
<style is:global>
  main.register-cwaaa {
    background-color: var(--grout-black);
  }
</style>

<style>
  .pledge-stage {
    padding-block: clamp(var(--space-xl), 6vw, var(--space-3xl));
    padding-inline: clamp(1rem, 5vw, 3rem);
  }
</style>
