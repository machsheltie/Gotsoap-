---
/**
 * /psas/<slug> — the metadata and content ORCHESTRATOR (specs.md §5.2).
 *
 * This route owns routing, SEO, JSON-LD, and content resolution — nothing
 * else. The visual stage is dispatched to five explicit environment
 * components, each of which owns its own DOM and CSS. No stage layout
 * lives here, by design: one configurable split-screen component is
 * prohibited (§5.2), and this file is deliberately incapable of becoming
 * one.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import ConfidentEnvironment from '../../components/psas/ConfidentEnvironment.astro';
import SmolderingEnvironment from '../../components/psas/SmolderingEnvironment.astro';
import UnholyEnvironment from '../../components/psas/UnholyEnvironment.astro';
import RedemptionEnvironment from '../../components/psas/RedemptionEnvironment.astro';
import ThirstEnvironment from '../../components/psas/ThirstEnvironment.astro';
import { POSTERS, absoluteUrl, type Poster } from '../../config/site';
import { posterCopy, meta } from '../../content/copy';

type PosterSlug = keyof typeof posterCopy;

export function getStaticPaths() {
  return POSTERS.map((poster) => ({
    params: { slug: poster.slug },
    props: { poster },
  }));
}

interface Props {
  poster: Poster;
}

/** One explicit environment per poster — the §5.2 dispatch table. */
const ENVIRONMENTS = {
  'confident-man': ConfidentEnvironment,
  'soap-smoldering': SmolderingEnvironment,
  unholy: UnholyEnvironment,
  redemption: RedemptionEnvironment,
  'thirst-announcement': ThirstEnvironment,
} as const;

const { poster } = Astro.props as Props;
const slug = poster.slug as PosterSlug;
const Environment = ENVIRONMENTS[slug];

const pageMeta = meta[`psas/${slug}` as keyof typeof meta];
const copyEntry = posterCopy[slug];

const prevPoster = POSTERS.find((p) => p.order === poster.order - 1);
const nextPoster = POSTERS.find((p) => p.order === poster.order + 1);

const downloadHref = `/downloads/${poster.slug}.jpg`;
const ogImage = absoluteUrl(downloadHref);
const pageUrl = absoluteUrl(`/psas/${poster.slug}`);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  name: poster.title,
  description: pageMeta.description,
  image: ogImage,
  url: pageUrl,
  creator: {
    '@type': 'Person',
    name: 'Stacey M. Breckel / Hope2 Studio',
  },
  about: 'A satirical hygiene-PSA campaign poster.',
  isPartOf: {
    '@type': 'CreativeWorkSeries',
    name: 'Got Soap? — Public Service Announcements, Series One',
  },
  position: poster.order,
  copyrightNotice: '© Stacey Breckel 2025',
};
---

<BaseLayout
  title={pageMeta.title}
  description={pageMeta.description}
  ogImage={ogImage}
  ogType="article"
  register={poster.register}
  jsonLd={jsonLd}
  hideScratchSniff
>
  <Environment
    poster={poster}
    alt={copyEntry.alt}
    caseNote={copyEntry.caseNote}
    pull={copyEntry.pull}
    pageUrl={pageUrl}
    downloadHref={downloadHref}
    prevPoster={prevPoster}
    nextPoster={nextPoster}
  />
</BaseLayout>
