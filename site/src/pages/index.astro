---
/**
 * / — Home: the MOVEMENT PITCH (specs.md §3), promoted from /movement-preview
 * per §13 step 2.
 *
 * Home recruits; routes convert (§2). Seven beats, each with its own job,
 * material, scale, and composition — no shared card shell or equal-height
 * section pattern controls the sequence (§3):
 *
 *   1 Hero          — §3.1 the steam threshold (text-free world + live type)
 *   2 Case          — §3.2 the Porcelain Evidence Wall
 *   3 Campaign      — §3.3 ONE flagship poster as propaganda → /psas
 *   4 Confrontation — §3.4 the Sniff Test invitation → /sniff-test
 *   5 Oath          — §3.5 the Gold Foil Summons → /pledge
 *   6 MovementReal  — §3.6 the one CWAAA seam: the Seal Takes the Page → /crisis
 *   7 Reveal        — the closing THESIS beat, no route (owner consolidation
 *                     2026-07-16: the home's one /about path is the footer
 *                     folio credit)
 *
 * The layout renders the site's one Masthead system (chrome unification,
 * 2026-07-16); `mastheadScale="monumental"` gives the home its magazine-cover
 * nameplate — every interior page runs the compact running head. The
 * BaseLayout Footer carries the §3.7 maker credit (footer-only per the
 * 2026-07-15 owner amendment). `hideScratchSniff` is REQUIRED here: the fixed
 * QC card would cross the flagship poster's box on scroll, and §3.3 says the
 * untouched poster is never overlaid (Sol Phase-3 F4 — the same defect class
 * already removed from the detail routes).
 * Normal vertical scrolling throughout (§3).
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/homev2/Hero.astro';
import Case from '../components/homev2/Case.astro';
import Campaign from '../components/homev2/Campaign.astro';
import Confrontation from '../components/homev2/Confrontation.astro';
import Oath from '../components/homev2/Oath.astro';
import MovementReal from '../components/homev2/MovementReal.astro';
import Reveal from '../components/homev2/Reveal.astro';
import { meta, nav } from '../content/copy';
import { SITE_URL } from '../config/site';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: nav.mark,
  url: SITE_URL,
  description: meta.home.description,
};
---

<BaseLayout
  title={meta.home.title}
  description={meta.home.description}
  jsonLd={jsonLd}
  mastheadScale="monumental"
  hideScratchSniff={true}
>
  <Hero />
  <Case />
  <Campaign />
  <Confrontation />
  <Oath />
  <MovementReal />
  <Reveal />
</BaseLayout>
