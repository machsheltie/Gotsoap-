---
/**
 * / — Home ("The Movement"). Task A. 🧼 (one 📋 seam: MovementLetterhead).
 *
 * The walk (design.md §7, copy-deck §3): steam-clear hero → five
 * individually-staged spots → Sniff Test insert → Movement letterhead seam →
 * pledge CTA band → reveal beat. Footer/nav/gag come from BaseLayout. Home is
 * MULTI-REGISTER, so no `register` prop is passed — each section sets its own.
 * Meta is verbatim (copy-deck §2).
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/home/Hero.astro';
import Spot from '../components/home/Spot.astro';
import SniffTestInsert from '../components/home/SniffTestInsert.astro';
import MovementLetterhead from '../components/home/MovementLetterhead.astro';
import PledgeBand from '../components/home/PledgeBand.astro';
import RevealBeat from '../components/home/RevealBeat.astro';
import { spots } from '../content/home';
import { SITE_URL } from '../config/site';

const description =
  'A public thirst announcement. Five posters, one demand: use the soap. Because "I usually shower" is not a hygiene routine. It\'s a confession.';

// Lightweight WebSite JSON-LD (Seo/OG tags come from BaseLayout).
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'got soap?',
  url: SITE_URL,
  description,
};
---

<BaseLayout title="got soap? — the movement" description={description} jsonLd={jsonLd}>
  {/* Sync marker: JS present → enable reveal-on-scroll; absent → content shows. */}
  <script is:inline>document.documentElement.classList.add('has-js');</script>

  <Hero />

  {spots.map((spot) => <Spot spot={spot} />)}

  <SniffTestInsert />
  <MovementLetterhead />
  <PledgeBand />
  <RevealBeat />
</BaseLayout>

<!--
  Reveal gating (no-JS safe). base.css hides [data-reveal] unconditionally, which
  would trap non-JS visitors with invisible content. Instead: reveal by default
  (beats base.css via `html` specificity), and only opt INTO the hidden-then-
  reveal behaviour once the `has-js` marker above confirms JS. Reduced-motion
  keeps everything visible.
-->
<style is:global>
  html [data-reveal] {
    opacity: 1;
    transform: none;
  }
  html.has-js [data-reveal] {
    opacity: 0;
    transform: translateY(12px);
  }
  html.has-js [data-reveal].is-revealed {
    opacity: 1;
    transform: none;
  }
  @media (prefers-reduced-motion: reduce) {
    html.has-js [data-reveal] {
      opacity: 1;
      transform: none;
    }
  }
</style>

<script>
  /**
   * Scroll-reveal activator (design.md §8 — quiet reveals only). The foundation
   * styles [data-reveal] but ships no activator, so this page-scoped island adds
   * `.is-revealed` as elements enter view. Pairs with the `has-js` gating above;
   * reduced-motion / no-IO just reveals everything.
   */
  const els = Array.from(
    document.querySelectorAll<HTMLElement>('[data-reveal]'),
  );

  const revealAll = () => els.forEach((el) => el.classList.add('is-revealed'));

  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (reduce || !('IntersectionObserver' in window)) {
    revealAll();
  } else {
    const io = new IntersectionObserver(
      (entries, obs) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-revealed');
            obs.unobserve(entry.target);
          }
        }
      },
      { rootMargin: '0px 0px -8% 0px', threshold: 0.08 },
    );
    els.forEach((el) => io.observe(el));
  }
</script>
