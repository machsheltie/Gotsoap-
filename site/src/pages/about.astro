---
/**
 * /about — The Reveal.
 * REDESIGNED as a sprawling, high-fashion agency portfolio case study.
 * Abandons the narrow text column for a massive, asymmetrical grid.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import { about, meta } from '../content/copy';
import { obfuscateEmail, EXTERNAL_LINKS, absoluteUrl } from '../config/site';

const aboutMeta = meta.about;

const whyEyebrow = 'Why it exists';
const caseStudyEyebrow = 'Case study';
const creditEyebrow = 'Credit & legal';
const behanceLabel = 'See the full campaign on Behance →';

const emailHtml = `<a class="about-emailLink" href="mailto:${obfuscateEmail()}">${obfuscateEmail()}</a>`;

const sameAs = [EXTERNAL_LINKS.behance].filter((url) => url.length > 0);
const aboutUrl = absoluteUrl('/about');
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Person',
      name: 'Stacey M. Breckel',
      jobTitle: 'Satirical Creative Director & Graphic Designer',
      url: aboutUrl,
      worksFor: { '@type': 'Organization', name: 'Hope2 Studio' },
      ...(sameAs.length > 0 ? { sameAs } : {}),
    },
    {
      '@type': 'Organization',
      name: 'Hope2 Studio',
      url: aboutUrl,
      founder: { '@type': 'Person', name: 'Stacey M. Breckel' },
      ...(sameAs.length > 0 ? { sameAs } : {}),
    },
  ],
};
---

<BaseLayout
  title={aboutMeta.title}
  description={aboutMeta.description}
  register="porcelain"
  jsonLd={jsonLd}
>
  <article class="reveal-stage">
    
    <header class="reveal-hero">
      <h1 class="reveal-title">{about.opening.heading}</h1>
      <p class="reveal-lead">{about.opening.body}</p>
    </header>

    <div class="reveal-grid">
      
      <!-- Left Column: Pitch & Contact (Anchored) -->
      <aside class="reveal-sidebar">
        <div class="reveal-sticky">
          <h2 class="sidebar-heading">{about.pitch.heading}</h2>
          <p class="sidebar-body">{about.pitch.body}</p>
          <p class="sidebar-tagline">{about.pitch.tagline}</p>

          <p class="sidebar-contact">
            <span set:html={emailHtml} />
          </p>

          {
            EXTERNAL_LINKS.behance && (
              <div class="sidebar-behance">
                <Button
                  label={behanceLabel}
                  href={EXTERNAL_LINKS.behance}
                  register="campaign"
                  variant="primary"
                />
              </div>
            )
          }
        </div>
      </aside>

      <!-- Right Column: Case Study Flow -->
      <div class="reveal-content">
        
        <section class="reveal-block">
          <h3 class="block-eyebrow">{whyEyebrow}</h3>
          <div class="block-text">
            {about.why.map((para) => <p>{para}</p>)}
          </div>
        </section>

        <section class="reveal-block">
          <h3 class="block-eyebrow">{caseStudyEyebrow}</h3>
          <div class="block-text">
            {
              about.caseStudy.map((item) => (
                <p>
                  <strong>{item.label}.</strong> {item.body}
                </p>
              ))
            }
          </div>
        </section>

        <section class="reveal-block reveal-block--credit">
          <h3 class="block-eyebrow">{creditEyebrow}</h3>
          <div class="block-text block-text--fine">
            <p>{about.credit}</p>
          </div>
        </section>

      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .reveal-stage {
    background-color: var(--steam-white);
    color: var(--grout-black);
    min-height: 100svh;
    padding-bottom: var(--space-3xl);
  }

  /* ---- Massive Hero ---- */
  .reveal-hero {
    padding: clamp(6rem, 15vh, 12rem) clamp(1.5rem, 5vw, 4rem);
    border-bottom: 2px solid var(--grout-black);
  }

  .reveal-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(4rem, 12vw, 10rem);
    line-height: 0.85;
    letter-spacing: -0.03em;
    color: var(--grout-black);
    margin-bottom: var(--space-lg);
    text-transform: lowercase;
  }

  .reveal-lead {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: clamp(1.2rem, 3vw, 2.5rem);
    line-height: 1.3;
    max-width: 30ch;
    color: var(--grout-black);
  }

  /* ---- Asymmetrical Grid ---- */
  .reveal-grid {
    display: flex;
    flex-direction: column;
  }
  @media (min-width: 900px) {
    .reveal-grid {
      flex-direction: row;
    }
  }

  /* ---- Sidebar ---- */
  .reveal-sidebar {
    flex: 1 1 40%;
    padding: clamp(2rem, 5vw, 4rem);
    background-color: var(--grout-black);
    color: var(--steam-white);
    border-bottom: 2px solid var(--grout-black);
  }
  @media (min-width: 900px) {
    .reveal-sidebar {
      border-right: 2px solid var(--grout-black);
      border-bottom: none;
    }
  }

  .reveal-sticky {
    position: sticky;
    top: clamp(2rem, 5vw, 4rem);
  }

  .sidebar-heading {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--step-4);
    line-height: 1.1;
    margin-bottom: var(--space-md);
    color: var(--lather-white);
  }

  .sidebar-body {
    font-family: var(--font-body);
    font-size: var(--step-1);
    line-height: 1.6;
    margin-bottom: var(--space-md);
    color: var(--chrome-mist);
  }

  .sidebar-tagline {
    font-family: var(--font-label);
    font-weight: 800;
    font-size: var(--step-0);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--marble-amber);
    margin-bottom: var(--space-xl);
  }

  .sidebar-contact {
    font-family: var(--font-display);
    font-size: var(--step-2);
  }
  .sidebar-contact :global(.about-emailLink) {
    color: var(--lather-white);
    text-decoration: none;
    border-bottom: 2px solid var(--marble-amber);
    transition: color 200ms ease, border-color 200ms ease;
  }
  .sidebar-contact :global(.about-emailLink:hover) {
    color: var(--marble-amber);
    border-color: transparent;
  }

  .sidebar-behance {
    margin-top: var(--space-xl);
  }

  /* ---- Content Blocks ---- */
  .reveal-content {
    flex: 1 1 60%;
    padding: clamp(2rem, 5vw, 4rem);
    display: flex;
    flex-direction: column;
    gap: clamp(4rem, 10vh, 8rem);
  }

  .reveal-block {
    max-width: 65ch;
  }

  .block-eyebrow {
    font-family: var(--font-label);
    font-weight: 900;
    font-size: var(--step--1);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--marble-amber);
    margin-bottom: var(--space-md);
    padding-bottom: var(--space-sm);
    border-bottom: 2px solid var(--grout-black);
    display: inline-block;
  }

  .block-text {
    font-family: var(--font-body);
    font-size: var(--step-1);
    line-height: 1.7;
    color: var(--grout-black);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .block-text :global(strong) {
    font-weight: 700;
  }

  .block-text--fine {
    font-family: var(--font-fine);
    font-size: var(--step--1);
    opacity: 0.7;
  }
</style>
