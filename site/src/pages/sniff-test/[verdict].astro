---
/**
 * /sniff-test/<verdict> — the four static, shareable verdict pages (Task B).
 *
 * Crawlable (getStaticPaths over the 4 slugs), each with its own title/description
 * + placeholder OG card. Shows the verdict card (glossy campaign card + CWAAA
 * stamp seam), then in-fiction controls (share/copy via ShareRow, download the
 * card, retake) and the pledge CTA. NO numeric score anywhere (design.md §7):
 * these pages are static URLs and cannot know a visitor's score — the names are
 * the joke. All copy verbatim from copy-deck §6.4.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import VerdictCard from '../../components/quiz/VerdictCard.astro';
import ShareRow from '../../components/ShareRow.astro';
import Button from '../../components/Button.astro';
import { verdicts, labels } from '../../content/copy';
import { absoluteUrl, type Register } from '../../config/site';

type VerdictSlug = keyof typeof verdicts;

export function getStaticPaths() {
  return (
    Object.entries(verdicts) as [VerdictSlug, (typeof verdicts)[VerdictSlug]][]
  ).map(([slug, v]) => ({
    params: { verdict: slug },
    props: { slug, ...v },
  }));
}

interface Props {
  slug: string;
  name: string;
  register: Register;
  lead: string;
  body: string;
  /** Per-verdict portable share payload (copy.ts `share` — Phase 4, F7). */
  share: string;
  /** Pledge-cue line above the CTA (copy.ts `exit`). */
  exit: string;
  /** Pledge CTA label (copy.ts `exitCta`). */
  exitCta: string;
}
const { slug, name, register, lead, body, share, exit, exitCta } = Astro.props;

const pageUrl = absoluteUrl(`/sniff-test/${slug}`);
// OG/share card path is a build/asset convention — copy.ts carries no image path.
const ogImagePath = `/og/verdict-${slug}.png`;
const ogImage = absoluteUrl(ogImagePath);
// Per-verdict meta isn't in copy.ts; derive it from the (copy) name + lead —
// reproduces the prior "<name> | got soap?" / lead pair exactly.
const metaTitle = `${name} | got soap?`;
// Phase 4 consensus (F7): each verdict ships its own portable payload — the
// one-size receipt (`sniffTest.shareDefault`) is retired.
const shareText = share;
---

<BaseLayout
  title={metaTitle}
  description={lead}
  ogImage={ogImage}
  ogType="article"
  register={register}
>
  <div class="verdict">
    <VerdictCard verdict={{ slug, register, name, lead, body }} />

    <div class="verdict__controls">
      <!-- Share verdict / copy the citation (in-fiction defaults for kind=verdict). -->
      <ShareRow
        kind="verdict"
        url={pageUrl}
        title={name}
        text={shareText}
      />
      <div class="verdict__row">
        <!-- Download the card (the placeholder OG image doubles as the share card). -->
        <Button
          label={labels.campaign.download}
          href={ogImagePath}
          download={`got-soap-${slug}.png`}
          register="campaign"
          variant="secondary"
        />
        <!-- Retake. -->
        <Button
          label={labels.campaign.retake}
          href="/sniff-test"
          register="campaign"
          variant="secondary"
        />
      </div>
    </div>

    <div class="verdict__pledge">
      <p class="verdict__cue">{exit}</p>
      <Button
        label={exitCta}
        href="/pledge"
        register="campaign"
        variant="primary"
      />
    </div>
  </div>
</BaseLayout>

<style>
  .verdict {
    inline-size: 100%;
    max-inline-size: 52rem;
    margin-inline: auto;
    padding-block: clamp(var(--space-2xl), 8vh, var(--space-3xl));
    padding-inline: clamp(1.25rem, 5vw, 2rem);
    display: flex;
    flex-direction: column;
    gap: var(--space-2xl);
  }

  .verdict__controls {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }
  .verdict__row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
  }

  .verdict__pledge {
    border-block-start: 1px solid var(--reg-rule);
    padding-block-start: var(--space-xl);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-md);
  }
  .verdict__cue {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: var(--step-1);
    color: var(--reg-heading);
  }
</style>
