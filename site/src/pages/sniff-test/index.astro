 * register (design.md §7); CWAAA fingerprint is the "FIELD ASSESSMENT CW-7" form
 * number only. One question per screen; scoring is internal; on completion the
 * island redirects to a static verdict page BY SLUG — no numeric score anywhere.
 * Meta verbatim from copy-deck §2.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import Quiz from '../../components/quiz/Quiz.astro';
import { meta } from '../../content/copy';

const pageMeta = meta['sniff-test'];
---

<BaseLayout
  title={pageMeta.title}
  description={pageMeta.description}
  register="porcelain"
>
  <Quiz />
</BaseLayout>
