---
/**
 * RevealBeat.astro — the quiet reveal beat (design.md §7, copy-deck §3.6). 🧼
 *
 * Deliberately SUBORDINATE: the portfolio reveal is the punchline on page
 * three, never the headline on page one (design.md §1). One chrome-mist line,
 * an attribution, and a low-key link to /about. Small, calm, no FX.
 */
import { reveal } from '../../content/home';
---

<section class="reveal" aria-label="About this campaign">
  <div class="reveal__inner" data-reveal>
    <p class="reveal__line">{reveal.line}</p>
    <p class="reveal__attr">
      {reveal.attribution}{' '}
      <a class="reveal__link" href={reveal.cta.href}>{reveal.cta.label}</a>
    </p>
  </div>
</section>

<style>
  .reveal {
    background: var(--grout-black);
    color: var(--chrome-mist);
    border-top: 1px solid color-mix(in srgb, var(--chrome-mist) 18%, transparent);
  }
  .reveal__inner {
    width: 100%;
    max-width: 52rem;
    margin-inline: auto;
    padding-inline: clamp(1.25rem, 5vw, 4rem);
    padding-block: clamp(2.5rem, 6vh, 4rem);
    text-align: center;
  }
  .reveal__line {
    font-family: var(--font-body);
    font-size: var(--step-0);
    color: var(--chrome-mist);
  }
  .reveal__attr {
    margin-top: 0.6rem;
    font-family: var(--font-fine);
    font-size: var(--step--1);
    color: color-mix(in srgb, var(--chrome-mist) 88%, var(--lather-white));
  }
  .reveal__link {
    color: var(--marble-amber);
    text-decoration: underline;
    text-underline-offset: 0.18em;
    white-space: nowrap;
  }
  .reveal__link:hover {
    color: color-mix(in srgb, var(--marble-amber) 84%, var(--lather-white));
  }
</style>
