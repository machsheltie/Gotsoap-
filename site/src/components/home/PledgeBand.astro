---
/**
 * PledgeBand.astro — the pledge CTA band (design.md §7, copy-deck §3.5). 🧼
 *
 * marble-amber on grout-black — the campaign's one gold accent, at full volume,
 * driving to /pledge. Marble register (grout-black ground, gold heading,
 * lather-white body). "Join the movement." carries the primary-CTA invariant.
 */
import { pledgeBand } from '../../content/home';
import Button from '../Button.astro';
---

<section class="pledge register-marble" aria-labelledby="pledge-heading">
  <div class="pledge__inner" data-reveal>
    <h2 id="pledge-heading" class="pledge__heading fx-gold">{pledgeBand.heading}</h2>
    <p class="pledge__body">{pledgeBand.body}</p>
    <div class="pledge__cta">
      <Button
        label={pledgeBand.cta.label}
        href={pledgeBand.cta.href}
        register="campaign"
        variant="primary"
      />
    </div>
  </div>
</section>

<style>
  .pledge {
    position: relative;
    border-block: 1px solid color-mix(in srgb, var(--marble-amber) 32%, transparent);
    background-image: radial-gradient(
      80% 120% at 50% 0%,
      color-mix(in srgb, var(--marble-amber) 12%, transparent),
      transparent 62%
    );
  }
  .pledge__inner {
    width: 100%;
    max-width: 52rem;
    margin-inline: auto;
    padding-inline: clamp(1.25rem, 5vw, 4rem);
    padding-block: clamp(3.5rem, 10vh, 6.5rem);
    text-align: center;
  }
  .pledge__heading {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--step-4);
    line-height: 1;
    text-transform: lowercase;
    max-width: 20ch;
    margin-inline: auto;
  }
  .pledge__body {
    margin-top: 1.1rem;
    font-family: var(--font-body);
    font-size: var(--step-1);
    color: var(--lather-white);
    max-width: 44ch;
    margin-inline: auto;
    text-wrap: pretty;
  }
  .pledge__cta {
    margin-top: clamp(1.5rem, 4vh, 2.25rem);
  }
</style>
