---
/**
 * SniffTestInsert.astro — the Sniff Test insert (design.md §7, copy-deck §3.3). 🧼
 *
 * A campaign-styled PORCELAIN card (not CWAAA) — the CWAAA presence is only the
 * Montserrat credit line ("Administered by CWAAA field assessors…"), a
 * fingerprint, not a change of author. Links to /sniff-test.
 *
 * Light-ground AA fix (as in Spot.astro): override the accent/focus slots to a
 * token-derived deep amber so anything reading --reg-accent passes on porcelain.
 */
import { sniffInsert } from '../../content/home';
import Button from '../Button.astro';
---

<section class="sniff register-porcelain" aria-labelledby="sniff-heading">
  <div class="sniff__inner" data-reveal>
    <div class="sniff__card">
      <p class="sniff__kicker">The Sniff Test</p>
      <h2 id="sniff-heading" class="sniff__heading">{sniffInsert.heading}</h2>
      <p class="sniff__body">{sniffInsert.body}</p>
      <div class="sniff__cta">
        <Button
          label={sniffInsert.cta.label}
          href={sniffInsert.cta.href}
          register="campaign"
          variant="primary"
        />
      </div>
      <p class="sniff__credit">{sniffInsert.credit}</p>
    </div>
  </div>
</section>

<style>
  .sniff {
    --reg-accent: color-mix(in srgb, var(--marble-amber) 68%, var(--grout-black));
    --focus-ring: color-mix(in srgb, var(--marble-amber) 68%, var(--grout-black));
    position: relative;
  }
  .sniff__inner {
    width: 100%;
    max-width: 72rem;
    margin-inline: auto;
    padding-inline: clamp(1.25rem, 5vw, 4rem);
    padding-block: clamp(3rem, 8vh, 6rem);
  }
  .sniff__card {
    max-width: 52rem;
    margin-inline: auto;
    text-align: center;
    padding: clamp(1.75rem, 5vw, 3.25rem);
    border: 1px solid var(--reg-rule);
    border-radius: var(--radius-tile);
    background: color-mix(in srgb, var(--lather-white) 55%, transparent);
  }
  .sniff__kicker {
    font-family: var(--font-label);
    font-weight: 800;
    font-size: var(--step--1);
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--reg-accent);
    margin-bottom: 0.75rem;
  }
  .sniff__heading {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--step-3);
    line-height: 1;
    text-transform: lowercase;
    color: var(--reg-heading);
    max-width: 24ch;
    margin-inline: auto;
  }
  .sniff__body {
    margin-top: 1rem;
    font-family: var(--font-body);
    font-size: var(--step-1);
    color: var(--reg-fg);
  }
  .sniff__cta {
    margin-top: clamp(1.25rem, 3.5vh, 2rem);
  }
  .sniff__credit {
    margin-top: 1.25rem;
    font-family: var(--font-fine);
    font-size: var(--step--2);
    letter-spacing: 0.01em;
    color: color-mix(in srgb, var(--reg-fg) 66%, var(--reg-bg));
  }
</style>
