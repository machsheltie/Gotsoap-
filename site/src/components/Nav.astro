---
/**
 * Nav.astro — global navigation (design.md §7, copy-deck §1).
 *
 * Thin grout-black bar: "got soap?" mark (Oswald lowercase, Medium) left;
 * Libre Franklin uppercase links right + a quiet ABOUT; marble-amber underline
 * for active/hover. Mobile: same bar with a plain disclosure toggle — NO
 * hamburger novelty. Progressive enhancement: with JS off the links simply
 * wrap and stay visible; the toggle only appears once JS marks the nav.
 */
import { nav } from '../content/copy';

// copy.ts stores the wordmark string only; the mark always links home.
const markHref = '/';
const path = Astro.url.pathname;
const normalize = (p: string) => (p !== '/' && p.endsWith('/') ? p.slice(0, -1) : p);
const here = normalize(path);
const isActive = (href: string): boolean =>
  href === '/' ? here === '/' : here === href || here.startsWith(href + '/');
---

<nav class="nav" aria-label="Primary">
  <a
    class="nav__mark"
    href={markHref}
    aria-current={isActive(markHref) ? 'page' : undefined}>{nav.mark}</a
  >

  <button
    class="nav__toggle"
    type="button"
    aria-expanded="false"
    aria-controls="nav-menu"
  >
    <span class="nav__toggle-label">Menu</span>
  </button>

  <ul id="nav-menu" class="nav__links" role="list">
    {
      nav.links.map((l) => (
        <li>
          <a
            class:list={['nav__link', isActive(l.href) && 'is-active']}
            href={l.href}
            aria-current={isActive(l.href) ? 'page' : undefined}
          >
            {l.label}
          </a>
        </li>
      ))
    }
    <li>
      <a
        class:list={[
          'nav__link',
          'nav__link--quiet',
          isActive(nav.quiet.href) && 'is-active',
        ]}
        href={nav.quiet.href}
        aria-current={isActive(nav.quiet.href) ? 'page' : undefined}
      >
        {nav.quiet.label}
      </a>
    </li>
  </ul>
</nav>

<script>
  const nav = document.querySelector<HTMLElement>('.nav');
  const toggle = nav?.querySelector<HTMLButtonElement>('.nav__toggle');
  const menu = nav?.querySelector<HTMLElement>('#nav-menu');
  if (nav && toggle && menu) {
    nav.classList.add('nav--js');
    toggle.addEventListener('click', () => {
      const open = menu.classList.toggle('is-open');
      toggle.setAttribute('aria-expanded', String(open));
    });
    // Collapse the mobile menu after following a link.
    menu.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).closest('a')) {
        menu.classList.remove('is-open');
        toggle.setAttribute('aria-expanded', 'false');
      }
    });
  }
</script>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    min-height: 56px;
    padding-inline: clamp(1.25rem, 5vw, 4rem);
    padding-block: 0.5rem;
    background: var(--grout-black);
    border-bottom: 1px solid color-mix(in srgb, var(--chrome-mist) 22%, transparent);
  }

  .nav__mark {
    font-family: var(--font-display);
    font-weight: 500; /* Medium — nav mark (design.md §5) */
    font-size: 1.5rem;
    letter-spacing: 0.02em;
    line-height: 1;
    color: var(--lather-white);
    text-decoration: none;
    text-transform: lowercase;
  }
  .nav__mark:hover {
    color: var(--marble-amber);
  }

  .nav__toggle {
    display: none; /* only shown on mobile when JS is present */
    font-family: var(--font-label);
    font-weight: 800;
    font-size: var(--step--1);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--lather-white);
    background: transparent;
    border: 1.5px solid color-mix(in srgb, var(--chrome-mist) 45%, transparent);
    border-radius: var(--radius-tile);
    padding: 0.4em 0.9em;
    cursor: pointer;
  }

  .nav__links {
    display: flex;
    align-items: center;
    gap: clamp(1rem, 2.4vw, 1.6rem);
    flex-wrap: wrap;
    margin: 0;
    padding: 0;
  }

  .nav__link {
    font-family: var(--font-label);
    font-weight: 800;
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--lather-white);
    text-decoration: none;
    padding-block: 0.35em;
    border-bottom: 2px solid transparent;
    transition: color 140ms ease, border-color 140ms ease;
  }
  .nav__link:hover,
  .nav__link.is-active {
    color: var(--marble-amber);
    border-bottom-color: var(--marble-amber);
  }
  .nav__link--quiet {
    font-weight: 700;
    font-size: 0.66rem;
    color: var(--chrome-mist);
  }
  .nav__link--quiet:hover,
  .nav__link--quiet.is-active {
    color: var(--marble-amber);
  }

  /* ---- Mobile disclosure (only active once JS adds .nav--js) ---- */
  @media (max-width: 767px) {
    .nav--js .nav__toggle {
      display: inline-flex;
    }
    .nav--js .nav__links {
      display: none;
      flex-basis: 100%;
      flex-direction: column;
      align-items: flex-start;
      gap: 0.25rem;
      padding-block: 0.5rem;
    }
    .nav--js .nav__links.is-open {
      display: flex;
    }
    .nav--js .nav__link {
      width: 100%;
    }
  }
</style>
