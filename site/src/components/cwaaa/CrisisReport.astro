---
/**
 * CrisisReport.astro — /crisis.
 * REDESIGNED: No longer a polite centered 46rem document.
 * This is an overwhelming, massive bureaucratic dossier. Brutalist scale,
 * edge-to-edge tables, and giant rubber-stamp typography.
 */
import Seal from './Seal.astro';
import RibbonBadge from './RibbonBadge.astro';
import Button from '../Button.astro';
import { crisis as c } from '../../content/copy';

const exits = [c.exits.assessment, c.exits.pledge];
const colFinding = 'Finding';
const colRef = 'Reference';
const immediateRelease = 'FOR IMMEDIATE RELEASE';
---

<article class="dossier-stage">
  
  <!-- Massive Letterhead -->
  <header class="dossier-lh">
    <div class="dossier-lh-seal">
      <Seal size={200} decorative />
    </div>
    <div class="dossier-lh-text">
      <p class="dossier-org">{c.header.org}</p>
      <p class="dossier-est"><em>{c.header.motto}</em></p>
      <p class="dossier-reg"><em>{c.header.sub}</em></p>
    </div>
    <h1 class="dossier-title">{c.header.title}</h1>
  </header>

  <div class="dossier-grid">
    
    <!-- Left Column: Founding & Scale -->
    <div class="dossier-col dossier-col--left">
      <section class="dossier-block" aria-label="Our founding">
        <div class="dossier-body">
          {c.founding.map((para, i) => (
            <p class={i === 0 ? 'founding-lede' : undefined}>{para}</p>
          ))}
        </div>
      </section>

      <div class="dossier-scale">
        <p>{c.scale}</p>
      </div>

      <section class="dossier-block dossier-ribbon" aria-labelledby="crisis-ribbon">
        <div class="ribbon-mark"><RibbonBadge size={120} decorative /></div>
        <h2 id="crisis-ribbon">{c.ribbon.heading}</h2>
        <p class="dossier-body">{c.ribbon.body}</p>
        <div class="ribbon-action">
          <Button
            label={c.ribbon.cta}
            href="/pledge"
            register="cwaaa"
            variant="primary"
          />
        </div>
      </section>
    </div>

    <!-- Right Column: Findings & Cases -->
    <div class="dossier-col dossier-col--right">
      
      <!-- Annual findings: Massive Table -->
      <section class="dossier-block" aria-labelledby="crisis-findings">
        <h2 id="crisis-findings" class="dossier-h2">{c.findings.heading}</h2>
        <p class="dossier-subtitle"><em>{c.findings.subnote}</em></p>
        
        <table class="dossier-table">
          <caption class="sr-only">{c.findings.heading}</caption>
          <thead>
            <tr>
              <th scope="col">{colFinding}</th>
              <th scope="col" class="col-ref">{colRef}</th>
            </tr>
          </thead>
          <tbody>
            {
              c.findings.rows.map((row) => (
                <tr>
                  <td class="dossier-body">{row.finding}</td>
                  <td class="finding-ref">{row.tag}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </section>

      <!-- Press Room -->
      <section class="dossier-block" aria-labelledby="crisis-press">
        <h2 id="crisis-press" class="dossier-h2">{c.pressRoom.heading}</h2>
        <ul class="press-list" role="list">
          {
            c.pressRoom.releases.map((r) => (
              <li class="release-item">
                <div class="release-stamp">{immediateRelease}</div>
                <div class="release-content">
                  <span class="release-date">{r.date}</span>
                  <h3 class="release-headline">{r.headline}</h3>
                  {r.body && <p class="release-body dossier-body"><em>{r.body}</em></p>}
                </div>
              </li>
            ))
          }
        </ul>
      </section>

      <!-- Recovery Case Files -->
      <section class="dossier-block dossier-cases" aria-labelledby="crisis-cases">
        <h2 id="crisis-cases" class="dossier-h2">{c.caseFiles.heading}</h2>
        <p class="dossier-subtitle"><em>{c.caseFiles.subhead}</em></p>
        
        <div class="case-grid">
          {
            c.caseFiles.files.map((file) => (
              <article class="case-card">
                <div class="case-tab">FILE {file.id}</div>
                <blockquote class="case-quote">{file.quote}</blockquote>
                <div class="case-meta">
                  <span class="case-name">{file.name}</span>
                  <span class="case-status">STATUS: {file.status}</span>
                </div>
              </article>
            ))
          }
        </div>

        <div class="case-closing-box">
          <p class="case-closing-line">{c.caseFiles.exitLine}</p>
          <Button
            label={c.caseFiles.exitCta}
            href="/sniff-test"
            register="cwaaa"
            variant="secondary"
          />
        </div>
      </section>
      
    </div>
  </div>

  <!-- Fine print & Exits -->
  <footer class="dossier-footer">
    <p class="dossier-fine"><em>{c.finePrint}</em></p>
    <nav class="dossier-exits" aria-label="Continue">
      {
        exits.map((exit, i) => (
          <Button
            label={exit.label}
            href={exit.href}
            register="cwaaa"
            variant={i === exits.length - 1 ? 'primary' : 'secondary'}
          />
        ))
      }
    </nav>
  </footer>

</article>

<style>
  .dossier-stage {
    padding: clamp(2rem, 5vw, 4rem);
    background-color: var(--cwaaa-paper);
    color: var(--reg-heading);
    min-height: 100svh;
    font-family: var(--font-cwaaa);
    /* PT Serif ships only 400/700 — no medium weight — so reading comfort
       comes from size (~17px mobile → 19px desktop), never from bolding. */
    --dossier-reading: clamp(1.0625rem, 1rem + 0.25vw, 1.1875rem);
    --font-typewriter: 'Courier New', Courier, monospace;
  }

  /* ---- Massive Letterhead ---- */
  .dossier-lh {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-xl);
    align-items: end;
    border-bottom: 8px solid var(--cwaaa-ink);
    padding-bottom: var(--space-xl);
    margin-bottom: var(--space-3xl);
  }
  @media (max-width: 800px) {
    .dossier-lh {
      grid-template-columns: 1fr;
      text-align: center;
      justify-items: center;
    }
  }

  .dossier-lh-seal :global(svg) {
    display: block;
    fill: var(--cwaaa-ink);
  }

  .dossier-org {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2rem, 5vw, 4rem);
    letter-spacing: -0.02em;
    text-transform: uppercase;
    line-height: 1;
    margin-bottom: var(--space-xs);
  }

  .dossier-title {
    grid-column: 1 / -1;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(3rem, 8vw, 7rem);
    line-height: 0.85;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    margin-top: var(--space-xl);
  }

  /* ---- Split Grid ---- */
  .dossier-grid {
    display: flex;
    flex-direction: column;
    gap: clamp(4rem, 8vw, 8rem);
  }
  @media (min-width: 1024px) {
    .dossier-grid {
      flex-direction: row;
      align-items: flex-start;
    }
    .dossier-col--left {
      flex: 0 0 35%;
      position: sticky;
      top: var(--space-2xl);
    }
    .dossier-col--right {
      flex: 1;
    }
  }

  /* ---- Typography ---- */
  /* Long-form narrative reads in PT Serif. The typewriter is an ACCENT,
     reserved for short stamped bits — refs, dates, file tabs, one-liners —
     never a paragraph. */
  .dossier-body {
    font-family: var(--font-cwaaa);
    font-size: var(--dossier-reading);
    line-height: 1.65;
    color: var(--cwaaa-ink);
  }
  .dossier-body p + p {
    margin-top: 1em;
  }
  .founding-lede {
    font-family: var(--font-typewriter);
    font-size: var(--step-0);
  }

  .dossier-h2 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--step-4);
    text-transform: uppercase;
    border-bottom: 3px solid var(--cwaaa-ink);
    padding-bottom: var(--space-xs);
    margin-bottom: var(--space-sm);
  }

  .dossier-subtitle {
    font-size: var(--step-0);
    margin-bottom: var(--space-xl);
    color: var(--reg-muted);
  }

  .dossier-block {
    margin-bottom: clamp(4rem, 8vh, 6rem);
  }

  /* ---- Scale & Ribbon ---- */
  .dossier-scale {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2rem, 4vw, 3.5rem);
    line-height: 1.1;
    padding: var(--space-xl) 0;
    border-block: 4px solid var(--reg-accent);
    margin-block: var(--space-3xl);
  }

  .dossier-ribbon {
    background: color-mix(in srgb, var(--cwaaa-ink) 5%, transparent);
    padding: var(--space-xl);
    border: 2px dashed var(--cwaaa-ink);
  }
  .ribbon-mark {
    margin-bottom: var(--space-md);
  }
  .dossier-ribbon h2 {
    font-family: var(--font-display);
    font-size: var(--step-2);
    font-weight: 700;
    margin-bottom: var(--space-md);
  }
  .ribbon-action {
    margin-top: var(--space-lg);
  }

  /* ---- Findings Table ---- */
  .dossier-table {
    width: 100%;
    border-collapse: collapse;
  }
  .dossier-table th {
    text-align: left;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--step-0);
    text-transform: uppercase;
    padding: var(--space-md) 0;
    border-bottom: 2px solid var(--cwaaa-ink);
  }
  .dossier-table td {
    padding: var(--space-lg) 0;
    border-bottom: 1px solid color-mix(in srgb, var(--cwaaa-ink) 20%, transparent);
    vertical-align: top;
  }
  .col-ref, .finding-ref {
    text-align: right;
    font-family: var(--font-typewriter);
    font-size: var(--step--1);
  }

  /* ---- Press Room Stamps ---- */
  .press-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xl);
  }
  .release-item {
    position: relative;
    padding: var(--space-xl);
    border: 1px solid var(--cwaaa-ink);
    background: var(--steam-white);
  }
  .release-stamp {
    position: absolute;
    top: -15px;
    left: -15px;
    font-family: var(--font-display);
    font-weight: 900;
    font-size: var(--step-1);
    color: var(--cwaaa-red);
    border: 4px solid var(--cwaaa-red);
    padding: 0.2em 0.5em;
    transform: rotate(-5deg);
    background: var(--cwaaa-paper);
    letter-spacing: 0.05em;
  }
  .release-date {
    display: block;
    font-family: var(--font-typewriter);
    color: var(--reg-muted);
    margin-bottom: var(--space-sm);
    margin-top: var(--space-md);
  }
  .release-headline {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--step-2);
    margin-bottom: var(--space-sm);
  }

  /* ---- Case Files ---- */
  .case-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-lg);
  }
  .case-card {
    background: color-mix(in srgb, var(--marble-amber) 15%, transparent);
    border-top: 15px solid var(--marble-amber);
    padding: var(--space-lg);
    position: relative;
  }
  .case-tab {
    position: absolute;
    top: -35px;
    right: 10px;
    background: var(--marble-amber);
    color: var(--grout-black);
    font-family: var(--font-typewriter);
    font-weight: 700;
    padding: 5px 15px;
    border-radius: 5px 5px 0 0;
  }
  .case-quote {
    font-size: var(--dossier-reading);
    line-height: 1.55;
    margin-bottom: var(--space-lg);
  }
  .case-meta {
    display: flex;
    justify-content: space-between;
    font-family: var(--font-display);
    font-size: var(--step--1);
    font-weight: 700;
    border-top: 1px dashed var(--cwaaa-ink);
    padding-top: var(--space-sm);
  }
  
  .case-closing-box {
    margin-top: var(--space-3xl);
    text-align: center;
    padding: var(--space-2xl);
    border: 4px solid var(--cwaaa-ink);
  }
  .case-closing-line {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--step-2);
    margin-bottom: var(--space-lg);
  }

  /* ---- Footer ---- */
  .dossier-footer {
    border-top: 8px solid var(--cwaaa-ink);
    padding-top: var(--space-2xl);
    margin-top: var(--space-3xl);
    text-align: center;
  }
  .dossier-fine {
    font-size: var(--step--1);
    color: var(--reg-muted);
    margin-bottom: var(--space-2xl);
  }
  .dossier-exits {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
