---
/**
 * Quiz.astro — the Sniff Test island shell (Task B; specs.md §8).
 *
 * Screens: intro → 7 questions one-at-a-time → transient completion beat →
 * client-side redirect to the static verdict page BY SLUG. Scoring is internal
 * plumbing; no numeric score is ever written to the DOM (§8).
 *
 * §8 contract carried here:
 *   - ONE route-level island holding all seven questions.
 *   - `.quiz` is the assessment shell: `min-block-size: 100svh`, height held
 *     stable by stacking every question in one grid cell (.quiz__form).
 *   - Tap-to-advance: answer activation records and advances (quiz.ts);
 *     the only nav control is a visible Back action.
 *   - Progress announcements via the aria-live region below.
 *
 * The whole surface is 🧼 campaign, porcelain register (BaseLayout sets it on
 * <main>). Behavior is in scripts/quiz.ts, driven by the data-* contract below;
 * the quiz needs JS to tally a verdict, so a <noscript> carries an in-voice
 * note and the Begin button hides when JS never arrives.
 */
import Progress from './Progress.astro';
import Question from './Question.astro';
import { sniffTest } from '../../content/copy';

const intro = sniffTest.intro;
const questions = sniffTest.questions;

// copy.ts stores the completion beat as one string; the beat bolds the first
// sentence (the constant head) and trails the remainder.
const beatSplit = sniffTest.completionBeat.indexOf('. ');
const beatHead =
  beatSplit > -1
    ? sniffTest.completionBeat.slice(0, beatSplit + 1)
    : sniffTest.completionBeat;
const beatRest =
  beatSplit > -1 ? sniffTest.completionBeat.slice(beatSplit + 2) : '';

/**
 * Client quiz config (score bands + redirect base + progress templates). Scoring
 * is internal plumbing — none of this renders a number; the client redirects by
 * verdict slug. Progress/aria TEMPLATES are derived from copy.ts's own label
 * functions by feeding them the "{n}" placeholder the client substitutes.
 * `dwellMs` (reading time) and `redirectBase` are build params, not copy.
 */
const N_TOKEN = '{n}' as unknown as number;
const quizConfig = {
  bands: sniffTest.bands,
  redirectBase: '/sniff-test/',
  dwellMs: 1200,
  progressTemplate: sniffTest.progressLabel(N_TOKEN),
  ariaTemplate: sniffTest.ariaProgress(N_TOKEN),
};

// Serialize ONLY score-band thresholds + redirect base for the client. These
// never render a number; the client redirects by verdict slug.
const configJson = JSON.stringify(quizConfig);
---

<section class="quiz" data-quiz>
  <script
    is:inline
    type="application/json"
    data-quiz-config
    set:html={configJson}
  />

  <!-- Screen 1: intro (§6.1) -->
  <div class="quiz__intro flow" data-quiz-intro>
    <h1 class="quiz__title fx-steam-glow">{intro.heading}</h1>
    <p class="quiz__lead">{intro.body}</p>
    <button type="button" class="quiz__begin" data-quiz-begin>{intro.cta}</button>
    <p class="quiz__credit">{intro.credit}</p>
  </div>

  <!-- Screens 2–8: the assessment (revealed by quiz.ts on Begin) -->
  <div class="quiz__assessment" data-quiz-assessment hidden>
    <Progress />

    <form class="quiz__form" data-quiz-form novalidate>
      {questions.map((question, i) => <Question index={i} question={question} />)}
    </form>

    <div class="quiz__nav">
      <button
        type="button"
        class="quiz__btn quiz__btn--ghost"
        data-quiz-back
        hidden
      >
        ← Back
      </button>
    </div>

    <p class="quiz__persist">{sniffTest.footerLine}</p>

    <!-- aria-live progress: announces the deck's exact "Question n of 7." -->
    <p class="sr-only" role="status" aria-live="polite" data-quiz-live></p>
  </div>

  <!-- Completion beat (§6.2b): transient, no score, then redirect. -->
  <div class="quiz__beat" data-quiz-beat hidden>
    <p class="quiz__beat-line" role="status" tabindex="-1" data-quiz-beat-line>
      <strong>{beatHead}</strong> {beatRest}
    </p>
  </div>

  <noscript>
    <p class="quiz__noscript">
      The Sniff Test tallies your findings in your browser — enable JavaScript to
      receive a verdict. Or consult your group chat. They already know.
    </p>
  </noscript>
</section>

<script>
  import '../../scripts/quiz.ts';
</script>

<style>
  /* §8: the stable assessment shell. min-block-size 100svh; the question stack
     below keeps the rendered height constant across all seven questions. */
  .quiz {
    position: relative;
    width: 100%;
    min-block-size: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: clamp(2rem, 5vw, 6rem);
    /* AA fix for light ground */
    --reg-accent: color-mix(in srgb, var(--marble-amber) 68%, var(--grout-black));
    --focus-ring: color-mix(in srgb, var(--marble-amber) 68%, var(--grout-black));
    overflow: hidden;
  }

  /* ---- Intro ---- */
  .quiz__intro {
    width: 100%;
    margin-inline: auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .quiz__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(4rem, 15vw, 12rem);
    line-height: 0.85;
    color: var(--reg-heading);
    text-transform: lowercase;
    margin-bottom: var(--space-xl);
    letter-spacing: -0.04em;
  }
  .quiz__lead {
    font-family: var(--font-body);
    font-size: clamp(1.2rem, 3vw, 2.5rem);
    line-height: 1.2;
    color: var(--reg-fg);
    max-width: 38ch;
    text-wrap: balance;
    margin-bottom: var(--space-2xl);
  }
  .quiz__credit {
    margin-top: var(--space-xl);
    font-family: var(--font-fine);
    font-size: clamp(0.7rem, 1vw, 0.9rem);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--reg-muted);
  }

  .quiz__begin {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2rem, 5vw, 4rem);
    text-transform: lowercase;
    color: var(--lather-white);
    background: var(--reg-accent);
    border: none;
    padding: 0.5em 1em;
    cursor: pointer;
    transition: background-color 0.3s ease, transform 0.2s ease;
  }
  .quiz__begin:hover {
    background: var(--grout-black);
  }
  .quiz__begin:active {
    transform: translateY(2px);
  }
  /* The assessment needs JS; when it never arrives, the <noscript> note speaks
     and the Begin button must not sit there dead. */
  :global(html:not(.has-js)) .quiz__begin {
    display: none;
  }

  /* ---- Assessment ---- */
  .quiz__assessment {
    width: 100%;
    max-width: 1400px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: 4vh;
  }
  /* display:flex would silently beat the UA's [hidden] rule — pin it. */
  .quiz__assessment[hidden] {
    display: none;
  }
  .quiz__intro[hidden] {
    display: none;
  }

  /* §8 stable shell: all seven questions occupy ONE grid cell, so the form's
     height is the tallest question and never changes as questions swap. */
  .quiz__form {
    display: grid;
    margin: 0;
    padding: 0;
    border: 0;
  }

  .quiz__nav {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: var(--space-md);
    margin-block-start: 4vh;
    border-top: 2px solid var(--grout-black);
    padding-top: 3vh;
  }
  .quiz__btn {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    text-transform: lowercase;
    padding: 0.5em 1em;
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
  }
  .quiz__btn--ghost {
    background: transparent;
    color: var(--reg-muted);
    border: 2px solid var(--reg-rule);
  }
  .quiz__btn--ghost:hover {
    color: var(--reg-fg);
    border-color: var(--reg-fg);
  }
  .quiz__btn[hidden] {
    display: none;
  }

  .quiz__persist {
    margin-block-start: 2vh;
    text-align: right;
    font-family: var(--font-fine);
    font-size: var(--step--1);
    font-style: italic;
    color: var(--reg-muted);
  }

  /* ---- Completion beat ---- */
  .quiz__beat {
    text-align: center;
    min-block-size: 60svh;
    display: grid;
    place-items: center;
  }
  .quiz__beat[hidden] {
    display: none;
  }
  .quiz__beat-line {
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 6rem);
    line-height: 0.9;
    max-inline-size: 20ch;
    color: var(--reg-fg);
    opacity: 0;
    animation: beat-in 800ms cubic-bezier(0.2, 0, 0, 1) forwards;
  }
  .quiz__beat-line strong {
    color: var(--reg-heading);
    font-weight: 700;
  }
  .quiz__beat-line:focus {
    outline: none;
  }
  @keyframes beat-in {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .quiz__beat-line {
      opacity: 1;
      animation: none;
    }
    .quiz__begin,
    .quiz__btn {
      transition: none;
    }
  }

  .quiz__noscript {
    font-family: var(--font-body);
    font-size: var(--step-1);
    text-align: center;
    color: var(--reg-fg);
    max-inline-size: 34ch;
    margin-inline: auto;
  }
</style>
