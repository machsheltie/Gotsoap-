---
/**
 * Question.astro — one Sniff Test question (Task B; specs.md §8).
 *
 * TAP-TO-ADVANCE (§8): each answer is a real <button>. Activation (tap, Enter,
 * Space) records the answer and advances — there is no Continue button. Buttons
 * — not radios — because native radio groups select on arrow-key NAVIGATION,
 * which would advance the visitor before they had browsed the options. With
 * buttons, Tab browses and only explicit activation commits.
 *
 * The recorded answer is exposed as aria-pressed (visible again when the
 * visitor comes Back); selected state is signalled by amber fill AND a longer
 * mark AND heavier text — never color alone (WCAG 1.4.1). The fieldset/legend
 * keeps group semantics; the prompt span is focus-managed by quiz.ts.
 *
 * All questions render server-side into ONE stacked grid cell (the stack lives
 * in Quiz.astro) so the assessment shell's height never changes between
 * questions (§8: stable shell). Inactive questions are `inert` + hidden by
 * data-state; quiz.ts activates one at a time with opacity + a short
 * horizontal transform (§8). The answer's index IS its score (0..3) — kept in
 * data-score, never rendered as a number anywhere on screen.
 */
import { sniffTest } from '../../content/copy';

/** One assessment question — copy.ts shape: { q: prompt, a: four answers }. */
type SniffQuestion = (typeof sniffTest.questions)[number];

interface Props {
  /** 0-based question index. */
  index: number;
  question: SniffQuestion;
}
const { index, question } = Astro.props;
const n = index + 1;
const promptId = `q${index}-prompt`;
---

<fieldset
  class="q"
  data-question={index}
  data-state="off"
  aria-labelledby={promptId}
  inert
>
  <legend class="q__legend">
    <span class="q__eyebrow">Question {n}</span>
    <span class="q__prompt" id={promptId} tabindex="-1">{question.q}</span>
  </legend>

  <div class="q__answers">
    {
      question.a.map((answer, i) => (
        <button
          type="button"
          class="answer"
          data-answer
          data-score={i}
          aria-pressed="false"
        >
          <span class="answer__mark" aria-hidden="true" />
          <span class="answer__text">{answer}</span>
        </button>
      ))
    }
  </div>
</fieldset>

<style>
  /* Stacked in one grid cell (grid on .quiz__form in Quiz.astro): every
     question contributes to the cell's height, so the shell height is the
     TALLEST question and never moves when questions swap (§8). */
  .q {
    grid-area: 1 / 1;
    border: 0;
    padding: 0;
    margin: 0;
    min-inline-size: 0;
    /* Off state: invisible, unfocusable (inert), nudged toward the exit side.
       --q-dir is set by quiz.ts: +1 entering/exiting rightward, -1 leftward. */
    opacity: 0;
    visibility: hidden;
    transform: translateX(calc(var(--q-dir, 1) * 16px));
    transition:
      opacity 300ms cubic-bezier(0.2, 0, 0, 1),
      transform 300ms cubic-bezier(0.2, 0, 0, 1),
      visibility 0s linear 300ms;
  }
  .q[data-state='active'] {
    opacity: 1;
    visibility: visible;
    transform: none;
    transition:
      opacity 300ms cubic-bezier(0.2, 0, 0, 1) 60ms,
      transform 300ms cubic-bezier(0.2, 0, 0, 1) 60ms,
      visibility 0s;
  }

  .q__legend {
    display: block;
    padding: 0;
    margin-block-end: 6vh;
  }
  .q__eyebrow {
    display: block;
    font-family: var(--font-label);
    font-weight: 900;
    font-size: clamp(0.9rem, 1.5vw, 1.2rem);
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--reg-accent);
    margin-block-end: 1vh;
  }
  .q__prompt {
    display: block;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(3rem, 8vw, 7rem);
    line-height: 0.95;
    letter-spacing: -0.02em;
    color: var(--reg-heading);
    max-inline-size: 26ch;
    text-wrap: balance;
  }
  .q__prompt:focus-visible {
    outline: 2px solid var(--focus-ring);
    outline-offset: 8px;
  }

  .q__answers {
    display: flex;
    flex-direction: column;
  }

  /* Full-width tappable row — a real button, styled as the editorial rule-row */
  .answer {
    display: flex;
    align-items: center;
    gap: 2vw;
    inline-size: 100%;
    text-align: start;
    padding: clamp(1.5rem, 4vh, 3.5rem) 0;
    border: 0;
    border-bottom: 2px solid color-mix(in srgb, var(--reg-rule) 60%, transparent);
    background: transparent;
    cursor: pointer;
    transition: all 0.4s cubic-bezier(0.2, 0, 0, 1);
  }
  .answer:first-child {
    border-top: 2px solid color-mix(in srgb, var(--reg-rule) 60%, transparent);
  }

  .answer:hover {
    border-bottom-color: var(--reg-accent);
    padding-left: 2vw;
  }

  /* Custom elegant minimal check */
  .answer__mark {
    flex: 0 0 auto;
    width: 2rem;
    height: 3px;
    background: color-mix(in srgb, var(--reg-muted) 30%, transparent);
    transition: all 0.4s cubic-bezier(0.2, 0, 0, 1);
  }

  .answer__text {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    line-height: 1.2;
    color: var(--reg-fg);
    transition: color 0.4s ease;
  }

  /* ---- Recorded state (visible again on Back; §8) ---- */
  .answer[aria-pressed='true'] {
    border-bottom-color: var(--reg-accent);
    padding-left: 2vw;
  }
  .answer[aria-pressed='true'] .answer__text {
    color: var(--grout-black);
    font-weight: 700;
  }
  .answer[aria-pressed='true'] .answer__mark {
    background: var(--reg-accent);
    width: 6rem;
  }

  /* §8/§11: reduced motion resolves the question swap immediately —
     no transform slide, no fade. */
  @media (prefers-reduced-motion: reduce) {
    .q,
    .q[data-state='active'],
    .answer,
    .answer__mark,
    .answer__text {
      transition: none;
    }
    .q {
      transform: none;
    }
  }
</style>
