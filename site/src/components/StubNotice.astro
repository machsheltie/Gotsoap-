---
/**
 * StubNotice.astro — Phase 0 placeholder body for a route.
 *
 * Provides the real page heading + a build note so `astro build` passes and
 * nav resolves before Phase 1 fan-out. Phase 1 route agents REPLACE the page
 * that renders this (this component can be deleted once all routes are built).
 */
interface Props {
  heading: string;
  route: string;
  owner: string;
}
const { heading, route, owner } = Astro.props;
---

<section class="stub">
  <div class="container container--narrow">
    <p class="stub__eyebrow">Got Soap? · Foundation scaffold</p>
    <h1 class="stub__heading">{heading}</h1>
    <p class="stub__note">
      Route <code>{route}</code> is scaffolded. Content and layout land in
      <strong>{owner}</strong>.
    </p>
  </div>
</section>

<style>
  .stub {
    padding-block: var(--space-3xl);
  }
  .stub__eyebrow {
    font-family: var(--font-label);
    font-weight: 800;
    font-size: var(--step--1);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--reg-accent, var(--marble-amber));
    margin-bottom: var(--space-sm);
  }
  .stub__heading {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--step-5);
    line-height: 1;
    text-transform: lowercase;
    color: var(--reg-heading, var(--lather-white));
    margin-bottom: var(--space-md);
  }
  .stub__note {
    font-family: var(--font-body);
    color: var(--reg-fg, var(--lather-white));
  }
  .stub__note code {
    font-family: var(--font-fine);
    background: color-mix(in srgb, currentColor 12%, transparent);
    padding: 0.1em 0.4em;
    border-radius: 2px;
  }
</style>
