---
/**
 * homev2/Reveal.astro — SECTION 7: THE CLOSING BEAT — the campaign thesis.
 *
 * One quiet line and NO route: "None of these men are real. The problem is
 * very, very real." It names neither the joke nor the maker — the imagery is
 * fantasy, the problem is real — so the home commits to the bit to its last
 * pixel (owner decision 2026-07-16, footer-consolidation spec). The former
 * meta-reveal tail and the who-is-behind-it cta are on the style-lock kill
 * list. The home's ONE path to /about is the footer folio credit, which
 * doubles as the §10 proof-lift trigger.
 *
 * Deliberately the quietest thing on the page: chrome-mist on grout-black,
 * no monumental type, no route, no confession.
 *
 * COPY: the line is VERBATIM from `home.revealBeat.line`.
 */
import { home } from '../../content/copy';
---

<section class="rv" aria-labelledby="rv-line">
  <div class="rv__inner">
    <span class="rv__mark" aria-hidden="true">✦</span>
    <h2 class="rv__line" id="rv-line">{home.revealBeat.line}</h2>
  </div>
</section>

<style>
  .rv {
    background-color: var(--grout-black);
    color: var(--chrome-mist);
    padding-block: clamp(3rem, 9vh, 6rem);
    padding-inline: clamp(1.25rem, 5vw, 4rem);
    text-align: center;
  }
  .rv__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(0.9rem, 2.5vh, 1.4rem);
  }
  .rv__mark {
    color: color-mix(in srgb, var(--marble-amber) 70%, transparent);
    font-size: 0.7rem;
  }
  .rv__line {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.15rem, 2.6vw, 1.9rem);
    line-height: 1.3;
    letter-spacing: 0.005em;
    color: var(--chrome-mist);
    max-width: 28ch;
    text-wrap: balance;
    margin: 0;
  }

  /* §6/§11: nothing here moves — the beat is a held breath, reduced motion or
     not. */
</style>
