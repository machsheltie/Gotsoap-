---
/**
 * homev2/Oath.astro — SECTION 5: THE OATH — **The Gold Foil Summons** (§3.5).
 *
 * The home invitation belongs to the CAMPAIGN, not CWAAA: an oversized
 * gold-foil fragrance insert crossing bright porcelain — the scented card that
 * falls out of a September issue, scaled to a billboard. Embossed rules, a
 * folded corner, and ONE perforated action line whose tear-off routes to
 * /pledge. No fields here — Form CW-1 lives at /pledge (§2) — and no manila:
 * this surface never imitates a document (§3.5).
 *
 * Mobile signature (§3.5): the foil insert is a diagonal band that enters from
 * the right, then settles into a full-width action plate. The entry uses
 * TRANSFORM ONLY (no opacity), driven by the global one-shot [data-reveal]
 * activator, so it cannot replay on scroll reversal. Desktop keeps the insert
 * crossing the porcelain at a standing angle. Reduced motion resolves
 * immediately to the settled composition.
 *
 * COPY: heading, body, cta are VERBATIM from `home.pledgeBand`. "Lather.
 * Rinse. Respect." is the movement's verbatim sign-off (pledge.oath /
 * crisis.motto). §7.2's witness-framing correction landed 2026-07-16
 * (Claude↔Sol consensus): he signs it, she sends it — still consumed verbatim.
 */
import { home } from '../../content/copy';
---

<section id="oath" class="oath register-porcelain" aria-labelledby="oath-h">
  <span class="oath__grain fx-grain" aria-hidden="true"></span>
  <div class="oath__bloom" aria-hidden="true"></div>

  <div class="oath__foil" data-reveal>
    <span class="oath__sheen" aria-hidden="true"></span>
    <span class="oath__fold" aria-hidden="true"></span>

    <div class="oath__body">
      <p class="oath__kicker">The Oath</p>
      <span class="oath__rule" aria-hidden="true"></span>
      <h2 id="oath-h" class="oath__h">{home.pledgeBand.heading}</h2>
      <p class="oath__copy">{home.pledgeBand.body}</p>
      <p class="oath__signoff">Lather. Rinse. Respect.</p>
    </div>

    <!-- The ONE perforated action line: the insert's tear-off stub. -->
    <a class="oath__action" href="/pledge">
      <span class="oath__action-label">{home.pledgeBand.cta}</span>
    </a>
  </div>
</section>

<style>
  .oath {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    background-color: var(--steam-white);
    color: var(--grout-black);
    padding-block: clamp(5rem, 15vh, 10.5rem);
    padding-inline: 0;
  }
  .oath__grain {
    opacity: 0.05;
    mix-blend-mode: multiply;
  }
  .oath__bloom {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      radial-gradient(70% 55% at 50% -4%, color-mix(in srgb, var(--lather-white) 85%, transparent), transparent 60%),
      radial-gradient(60% 46% at 50% 104%, color-mix(in srgb, var(--marble-amber) 13%, transparent), transparent 70%),
      radial-gradient(40% 32% at 12% 40%, color-mix(in srgb, var(--steam-white) 80%, transparent), transparent 66%);
  }

  /* ---- The foil insert ------------------------------------------------------
     Wider than the viewport and set at a standing angle, so it reads as an
     object crossing the porcelain, not a section in a container. */
  .oath__foil {
    position: relative;
    z-index: 1;
    width: 112%;
    margin-left: -6%;
    transform: rotate(-3.25deg);
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: stretch;
    background:
      linear-gradient(
        104deg,
        color-mix(in srgb, var(--lather-white) 30%, transparent) 0%,
        transparent 22%,
        color-mix(in srgb, var(--lather-white) 18%, transparent) 47%,
        transparent 60%,
        color-mix(in srgb, var(--grout-black) 14%, transparent) 100%
      ),
      linear-gradient(168deg, #d9ad55 0%, var(--marble-amber) 38%, #94681d 64%, #c99f49 100%);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.55) inset,
      0 -1px 0 rgba(58, 40, 8, 0.4) inset,
      0 34px 70px -30px rgba(58, 40, 8, 0.55);
  }
  /* Brushed-foil banding: faint vertical mill lines across the whole insert. */
  .oath__sheen {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: repeating-linear-gradient(
      92deg,
      transparent 0 7px,
      rgba(255, 255, 255, 0.05) 7px 9px,
      transparent 9px 14px,
      rgba(58, 40, 8, 0.04) 14px 16px
    );
  }
  /* The folded edge: a turned-down flap on the insert's top edge. Anchored
     inside the visible field — the true top-right corner overhangs the
     viewport on desktop (the insert crosses the porcelain), so a corner fold
     would be clipped out of existence there. */
  .oath__fold {
    position: absolute;
    top: 0;
    right: calc(6% + 2.5rem);
    width: clamp(2.5rem, 5vw, 4.25rem);
    height: clamp(2.5rem, 5vw, 4.25rem);
    background:
      linear-gradient(
        225deg,
        var(--steam-white) 0%,
        var(--steam-white) 49.5%,
        #e7c47c 50%,
        #b98d33 76%,
        #8a5f1a 100%
      );
    filter: drop-shadow(-3px 4px 6px rgba(58, 40, 8, 0.3));
  }

  .oath__body {
    padding: clamp(2.5rem, 7vh, 4.5rem) clamp(2rem, 10vw, 11rem);
  }

  .oath__kicker {
    font-family: var(--font-label);
    font-weight: 800;
    font-size: var(--step--1);
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--grout-black) 78%, var(--marble-amber));
  }
  /* Embossed rule: pressed into the foil — light crest above, shade below. */
  .oath__rule {
    display: block;
    width: min(100%, 26rem);
    height: 0;
    margin-top: clamp(0.8rem, 2vh, 1.2rem);
    border-top: 1px solid rgba(58, 40, 8, 0.45);
    border-bottom: 1px solid rgba(255, 244, 214, 0.55);
  }
  .oath__h {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.3rem, 6.5vw, 4.75rem);
    /* ≥1.05: sub-1.0 display leading is the clipping class (home pass 2026-07-16). */
    line-height: 1.05;
    letter-spacing: -0.02em;
    max-width: 16ch;
    margin-top: clamp(1.1rem, 3vh, 1.9rem);
    color: var(--grout-black);
    /* embossed ink: struck into the foil rather than printed on it */
    text-shadow:
      0 1px 0 rgba(255, 244, 214, 0.4),
      0 -1px 1px rgba(58, 40, 8, 0.35);
  }
  .oath__copy {
    font-family: var(--font-body);
    font-size: var(--step-1);
    line-height: 1.5;
    color: color-mix(in srgb, var(--grout-black) 88%, var(--marble-amber));
    margin-top: clamp(1rem, 3vh, 1.6rem);
    max-width: 40ch;
  }
  .oath__signoff {
    font-family: var(--font-label);
    font-weight: 900;
    font-size: var(--step--1);
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--grout-black) 74%, var(--marble-amber));
    margin-top: clamp(1.5rem, 4vh, 2.25rem);
  }

  /* ---- The perforated action line -------------------------------------------
     A tear-off stub behind ONE perforation: punched holes expose the porcelain
     beneath the foil. The whole stub is the route to /pledge. */
  .oath__action {
    position: relative;
    display: grid;
    place-content: center;
    padding: clamp(2rem, 6vh, 3.5rem) clamp(1.75rem, 4vw, 3.5rem);
    padding-right: clamp(4rem, 12vw, 13rem);
    text-decoration: none;
    background: linear-gradient(168deg, #c79c45 0%, #a97a24 55%, #8a5f1a 100%);
  }
  .oath__action::before {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    left: 0;
    width: 3px;
    background-image: radial-gradient(
      circle at 50% 50%,
      var(--steam-white) 0 1.6px,
      transparent 2px
    );
    background-size: 3px 11px;
    background-repeat: repeat-y;
    filter: drop-shadow(1px 0 0 rgba(58, 40, 8, 0.35));
  }
  .oath__action-label {
    font-family: var(--font-label);
    font-weight: 900;
    font-size: clamp(1rem, 1.9vw, 1.4rem);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--lather-white);
    text-shadow: 0 1px 2px rgba(58, 40, 8, 0.55);
    border-bottom: 2px solid color-mix(in srgb, var(--lather-white) 55%, transparent);
    padding-bottom: 0.25em;
    transition: border-color 140ms ease;
  }
  .oath__action:hover .oath__action-label,
  .oath__action:focus-visible .oath__action-label {
    border-bottom-color: var(--lather-white);
  }
  .oath__action:focus-visible {
    outline: 3px solid var(--focus-ring);
    outline-offset: -6px;
  }

  /* ---- Entry: transform only, one-shot ---------------------------------------
     Override the global [data-reveal] fade: the foil never changes opacity
     (§3.5 "the transition uses transform only"); it arrives along its own
     axis and settles. .is-revealed is never removed → no replay on reversal. */
  :global(.has-js) .oath__foil[data-reveal] {
    opacity: 1;
    transform: translateX(9%) rotate(-3.25deg);
    transition: transform 800ms cubic-bezier(0.22, 0.9, 0.3, 1);
  }
  :global(.has-js) .oath__foil[data-reveal].is-revealed {
    opacity: 1;
    transform: rotate(-3.25deg);
  }

  /* ---- Mobile: the diagonal band settles into a full-width action plate ----- */
  @media (max-width: 720px) {
    .oath__foil {
      width: 100%;
      margin-left: 0;
      transform: none;
      grid-template-columns: 1fr;
    }
    :global(.has-js) .oath__foil[data-reveal] {
      transform: translateX(64%) rotate(-7deg);
      transition: transform 850ms cubic-bezier(0.22, 0.9, 0.3, 1);
    }
    :global(.has-js) .oath__foil[data-reveal].is-revealed {
      transform: none;
    }
    .oath__body {
      padding: clamp(2.25rem, 6vh, 3rem) clamp(1.25rem, 6vw, 2rem);
    }
    /* The stub becomes the full-width action plate; the perforation runs
       horizontally above it. */
    .oath__action {
      padding: clamp(1.5rem, 4.5vh, 2.25rem) clamp(1.25rem, 6vw, 2rem);
      justify-content: start;
    }
    .oath__action::before {
      top: 0;
      bottom: auto;
      left: 0;
      right: 0;
      width: auto;
      height: 3px;
      background-size: 11px 3px;
      background-repeat: repeat-x;
      filter: drop-shadow(0 1px 0 rgba(58, 40, 8, 0.35));
    }
    .oath__fold {
      /* full-width plate on mobile: the fold returns to the true corner */
      right: 0;
      width: clamp(2rem, 9vw, 2.75rem);
      height: clamp(2rem, 9vw, 2.75rem);
    }
  }

  /* §3.5/§6/§11: reduced motion resolves immediately to the settled insert. */
  @media (prefers-reduced-motion: reduce) {
    :global(.has-js) .oath__foil[data-reveal],
    :global(.has-js) .oath__foil[data-reveal].is-revealed {
      transform: rotate(-3.25deg);
      transition: none;
    }
    .oath__action-label {
      transition: none;
    }
  }
  @media (prefers-reduced-motion: reduce) and (max-width: 720px) {
    :global(.has-js) .oath__foil[data-reveal],
    :global(.has-js) .oath__foil[data-reveal].is-revealed {
      transform: none;
    }
  }
</style>
