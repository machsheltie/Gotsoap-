---
/**
 * Footer.astro — the poster footer, translated (design.md §7, copy-deck §1).
 * Every string here is a verbatim voice invariant. The "Funded by …" line is
 * the 🧼→📋 seam (links /crisis). Consolidation (owner, 2026-07-16): the folio
 * credit below is the site's ONE /about path — the © line is plain text, and
 * the parody disclaimer moved to /about, reworded as legal fine print. Social
 * links render only when their config URL is non-empty (PRD §5.6) — absent
 * means invisible.
 */
import { footer } from '../content/copy';
import { EXTERNAL_LINKS } from '../config/site';

// copy.ts holds the hashtag stack as an array; the footer renders it middot-joined.
const hashtagLine = footer.hashtags.join(' · ');
// The "Funded by …" seam links /crisis (copy.ts comments).
const fundedHref = '/crisis';

const socialLabels: Record<string, string> = footer.socialLabels;
const socials = (
  Object.entries(EXTERNAL_LINKS) as [string, string][]
).filter(([, url]) => url.trim().length > 0);
---

<footer class="footer">
  <div class="container">
    <p class="footer__movement">{footer.movementLine}</p>

    <p class="footer__hashtags">{hashtagLine}</p>

    <p class="footer__funded">
      {footer.fundedByLead} <a href={fundedHref}>{footer.fundedBy}</a>
    </p>

    <p class="footer__copyright">{footer.credit}</p>

    <!-- The production folio credit (§3.7 as amended 2026-07-15, G11):
         FOOTER-ONLY, and the source string is the approved literal — real
         caps in the markup, not lower-case dressed up by small-caps CSS
         (Sol Phase-3 F6). Gate G11 greps THIS file for the verbatim literal,
         so it stays hardcoded here by design (the gate's own comment: it does
         not route through the copy lane). Linked to /about — the ONE campaign
         path to the reveal (2026-07-16 consolidation) and the §10 proof-lift
         trigger. -->
    <p class="footer__folio">
      <a href="/about">PRODUCED BY HOPE2 STUDIO · DIRECTED BY STACEY BRECKEL</a>
    </p>

    {
      socials.length > 0 && (
        <ul class="footer__socials" role="list">
          {socials.map(([key, url]) => (
            <li>
              <a href={url} rel="me noopener" target="_blank">
                {socialLabels[key] ?? key}
              </a>
            </li>
          ))}
        </ul>
      )
    }

  </div>
</footer>

<style>
  .footer {
    background: var(--grout-black);
    color: var(--chrome-mist);
    border-top: 1px solid color-mix(in srgb, var(--chrome-mist) 30%, transparent);
    padding-block: var(--space-2xl) var(--space-xl);
    margin-top: auto;
  }
  .footer .container {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    text-align: center;
  }
  .footer__movement {
    font-family: var(--font-label);
    font-weight: 900;
    font-size: var(--step-1);
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--lather-white);
    max-width: var(--measure);
    margin-inline: auto;
  }
  .footer__hashtags {
    font-family: var(--font-label);
    font-weight: 800;
    font-size: var(--step--1);
    letter-spacing: 0.1em;
    color: var(--chrome-mist);
  }
  .footer__funded,
  .footer__copyright {
    font-family: var(--font-fine);
    font-size: var(--step--1);
    color: var(--chrome-mist);
  }
  .footer a {
    color: var(--marble-amber);
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }
  .footer__folio a {
    font-family: var(--font-fine);
    /* the source string carries the caps (§3.7 "this exact credit"); the CSS
       only sizes and tracks it like a production card */
    font-size: var(--step--2);
    letter-spacing: 0.2em;
    color: var(--chrome-mist);
    text-decoration: none;
  }
  .footer__folio a:hover {
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }
  .footer__socials {
    display: flex;
    justify-content: center;
    gap: 1.25rem;
    margin: 0.35rem 0;
    padding: 0;
  }
  .footer__socials a {
    font-family: var(--font-label);
    font-weight: 800;
    font-size: var(--step--2);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
  }
  .footer__socials a:hover {
    text-decoration: underline;
  }
</style>
