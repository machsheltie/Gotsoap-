---
/**
 * Footer.astro — the poster footer, translated (design.md §7, copy-deck §1).
 * Every string here is a verbatim voice invariant. The "Funded by …" line is
 * the 🧼→📋 seam (links /crisis); the © line links /about. Social links render
 * only when their config URL is non-empty (PRD §5.6) — absent means invisible.
 */
import { footer } from '../content/copy';
import { EXTERNAL_LINKS } from '../config/site';

// copy.ts holds the hashtag stack as an array; the footer renders it middot-joined.
const hashtagLine = footer.hashtags.join(' · ');
// The "Funded by …" seam links /crisis; the © credit links /about (copy.ts comments).
const fundedHref = '/crisis';
const creditHref = '/about';

const socialLabels: Record<string, string> = {
  behance: 'Behance',
  instagram: 'Instagram',
  facebook: 'Facebook',
};
const socials = (
  Object.entries(EXTERNAL_LINKS) as [string, string][]
).filter(([, url]) => url.trim().length > 0);
---

<footer class="footer">
  <div class="container">
    <p class="footer__movement">{footer.movementLine}</p>

    <p class="footer__hashtags">{hashtagLine}</p>

    <p class="footer__funded">
      Funded by <a href={fundedHref}>{footer.fundedBy}</a>
    </p>

    <p class="footer__copyright">
      <a href={creditHref}>{footer.credit}</a>
    </p>

    {
      socials.length > 0 && (
        <ul class="footer__socials" role="list">
          {socials.map(([key, url]) => (
            <li>
              <a href={url} rel="me noopener" target="_blank">
                {socialLabels[key] ?? key}
              </a>
            </li>
          ))}
        </ul>
      )
    }

    <p class="footer__disclaimer">{footer.disclaimer}</p>
  </div>
</footer>

<style>
  .footer {
    background: var(--grout-black);
    color: var(--chrome-mist);
    border-top: 1px solid color-mix(in srgb, var(--chrome-mist) 30%, transparent);
    padding-block: var(--space-2xl) var(--space-xl);
    margin-top: auto;
  }
  .footer .container {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    text-align: center;
  }
  .footer__movement {
    font-family: var(--font-label);
    font-weight: 900;
    font-size: var(--step-1);
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--lather-white);
    max-width: var(--measure);
    margin-inline: auto;
  }
  .footer__hashtags {
    font-family: var(--font-label);
    font-weight: 800;
    font-size: var(--step--1);
    letter-spacing: 0.1em;
    color: var(--chrome-mist);
  }
  .footer__funded,
  .footer__copyright {
    font-family: var(--font-fine);
    font-size: var(--step--1);
    color: var(--chrome-mist);
  }
  .footer a {
    color: var(--marble-amber);
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }
  .footer__socials {
    display: flex;
    justify-content: center;
    gap: 1.25rem;
    margin: 0.35rem 0;
    padding: 0;
  }
  .footer__socials a {
    font-family: var(--font-label);
    font-weight: 800;
    font-size: var(--step--2);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
  }
  .footer__socials a:hover {
    text-decoration: underline;
  }
  .footer__disclaimer {
    font-family: var(--font-fine);
    font-size: var(--step--2);
    font-style: italic;
    line-height: 1.5;
    color: color-mix(in srgb, var(--chrome-mist) 80%, transparent);
    max-width: 52ch;
    margin: 0.5rem auto 0;
  }
</style>
