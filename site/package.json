{
  "name": "gotsoap-site",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "gates": "node scripts/gates.mjs",
    "gates:phase": "node scripts/gates.mjs --phase",
    "gates:build": "astro build && node scripts/gates.mjs --build",
    "gates:prod": "astro build && node scripts/gates.mjs --build --prod",
    "distinguish": "node scripts/distinguishability.mjs",
    "copy-gates": "node --experimental-strip-types scripts/copy-gates.mjs",
    "fidelity": "node --experimental-strip-types scripts/fidelity-check.mjs",
    "authority": "node scripts/authority-check.mjs",
    "authority:test": "node scripts/authority-check.test.mjs"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^7.0.7",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@fontsource/jost": "^5.2.8",
    "@fontsource/libre-franklin": "^5.2.8",
    "@fontsource/montserrat": "^5.2.8",
    "@fontsource/oswald": "^5.2.8",
    "@fontsource/pt-serif": "^5.2.8",
    "typescript": "^6.0.3"
  }
}
